DB_HOST_PORT=5432
MIDDLEWARE_PORT=8000
SIMULATOR_PORT=8001
HOST_IP=10.22.1.247
ALLOWED_HOSTS=localhost,127.0.0.1,10.22.1.247,*
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://10.22.1.247,http://10.22.1.247:8000
# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=middts
POSTGRES_PASSWORD=middts
POSTGRES_DB=middts
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=middts123
NEO4J_URL=neo4j:7687
# NEO4J_AUTH format: user/password. Setting to middts/middts will set initial admin credentials.
NEO4J_AUTH=neo4j/middts123

# InfluxDB
#Use the scenario admin token
INFLUXDB_INIT_USERNAME=middts
INFLUXDB_INIT_PASSWORD=middts123
INFLUXDB_INIT_ORG=middts
INFLUXDB_INIT_BUCKET=iot_data
INFLUXDB_INIT_ADMIN_TOKEN=middts_token
INFLUXDB_TOKEN=middts_token
INFLUXDB_HOST=influxdb
INFLUXDB_PORT=8086
INFLUXDB_BUCKET=iot_data
INFLUXDB_ORGANIZATION=middts

USE_INFLUX_TO_EVALUATE=True
ENABLE_INFLUX_LATENCY_MEASUREMENTS=False

# ThingsBoard credentials (shared)
THINGSBOARD_USER=tenant@thingsboard.org
THINGSBOARD_PASSWORD=tenant
THINGSBOARD_MQTT_PORT=1883
THINGSBOARD_MQTT_KEEP_ALIVE=60

# Middleware ThingsBoard target
MIDDLEWARE_THINGSBOARD_HOST=demo.thingsboard.io
MIDDLEWARE_TB_HOST=demo.thingsboard.io
MIDDLEWARE_TB_PORT=443
MIDDLEWARE_TB_SCHEME=https

# Middleware listener behavior
START_LISTENER_AFTER_TB=0

# Simulator ThingsBoard target (full URL)
SIMULATOR_THINGSBOARD_HOST=https://demo.thingsboard.io

# Simulator behavior
SIMULATOR_NUMBER=1
HEARTBEAT_INTERVAL=5
RANDOMIZE=1
USE_MEMORY_STATE=1
SIMULATOR_DEBUG=False
SIMULATOR_ALLOWED_HOSTS=*
SIMULATOR_INFLUXDB_BUCKET=iot_data

# Default Django superuser for middleware & simulator (createsuperuser will be executed on boot)
DJANGO_SUPERUSER_USERNAME=middts
DJANGO_SUPERUSER_PASSWORD=middts123
DJANGO_SUPERUSER_EMAIL=middts@example.com

# Optional separate simulator superuser (if simulator uses different credentials)
SIMULATOR_SUPERUSER_USERNAME=middts
SIMULATOR_SUPERUSER_PASSWORD=middts123
SIMULATOR_SUPERUSER_EMAIL=middts@example.com